generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String?           @unique
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  CustomerSession CustomerSession[]
  DiningTable     DiningTable[]
  MenuCategory    MenuCategory[]
  MenuItem        MenuItem[]
  Order           Order[]
  StaffUser       StaffUser[]
}

model DiningTable {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id   String            @db.Uuid
  table_number    String
  qr_token        String            @unique
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  CustomerSession CustomerSession[]
  Restaurant      Restaurant        @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Order           Order[]

  @@index([restaurant_id], map: "idx_dining_table_restaurant_id")
}

model CustomerSession {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id  String      @db.Uuid
  table_id       String      @db.Uuid
  session_token  String      @unique
  customer_name  String?
  customer_phone String?
  is_active      Boolean     @default(true)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  Restaurant     Restaurant  @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  DiningTable    DiningTable @relation(fields: [table_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Order          Order[]

  @@index([table_id], map: "idx_customer_session_table_id")
}

model MenuCategory {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id String     @db.Uuid
  name          String
  description   String?
  sort_order    Int        @default(0)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  Restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  MenuItem      MenuItem[]

  @@index([restaurant_id], map: "idx_menu_category_restaurant_id")
}

model MenuItem {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id String       @db.Uuid
  category_id   String       @db.Uuid
  name          String
  description   String?
  price         Decimal      @db.Decimal(10, 2)
  is_veg        Boolean      @default(false)
  is_popular    Boolean      @default(false)
  is_new        Boolean      @default(false)
  is_available  Boolean      @default(true)
  station       station_type @default(KITCHEN)
  image_url     String?
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  MenuCategory  MenuCategory @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Restaurant    Restaurant   @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  OrderItem     OrderItem[]

  @@index([category_id], map: "idx_menu_item_category_id")
  @@index([restaurant_id], map: "idx_menu_item_restaurant_id")
}

model Order {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id       String           @db.Uuid
  table_id            String           @db.Uuid
  customer_session_id String?          @db.Uuid
  kot_number          String?          @unique
  status              order_status     @default(PENDING_CONFIRMATION)
  notes               String?
  total_amount        Decimal          @default(0) @db.Decimal(10, 2)
  placed_at           DateTime         @default(now()) @db.Timestamptz(6)
  confirmed_at        DateTime?        @db.Timestamptz(6)
  sent_to_kitchen_at  DateTime?        @db.Timestamptz(6)
  ready_at            DateTime?        @db.Timestamptz(6)
  served_at           DateTime?        @db.Timestamptz(6)
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  CustomerSession     CustomerSession? @relation(fields: [customer_session_id], references: [id], onUpdate: NoAction)
  Restaurant          Restaurant       @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  DiningTable         DiningTable      @relation(fields: [table_id], references: [id], onUpdate: NoAction)
  OrderEvent          OrderEvent[]
  OrderItem           OrderItem[]

  @@index([restaurant_id], map: "idx_order_restaurant_id")
  @@index([status], map: "idx_order_status")
  @@index([table_id], map: "idx_order_table_id")
}

model OrderItem {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String            @db.Uuid
  menu_item_id       String?           @db.Uuid
  item_name_snapshot String
  price_snapshot     Decimal           @db.Decimal(10, 2)
  quantity           Int
  item_notes         String?
  station            station_type      @default(KITCHEN)
  status             order_item_status @default(PENDING)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  MenuItem           MenuItem?         @relation(fields: [menu_item_id], references: [id], onUpdate: NoAction)
  Order              Order             @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_item_order_id")
  @@index([status], map: "idx_order_item_status")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model OrderEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  event_type String
  actor_type String?
  actor_id   String?  @db.Uuid
  payload    Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  Order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_event_order_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model StaffUser {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurant_id String     @db.Uuid
  full_name     String
  email         String?    @unique
  password_hash String
  role          staff_role
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  Restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum order_item_status {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
  OUT_OF_STOCK
}

enum order_status {
  PENDING_CONFIRMATION
  CONFIRMED
  SENT_TO_KITCHEN
  READY
  SERVED
  CANCELLED
  CLOSED
}

enum staff_role {
  ADMIN
  WAITER
  KITCHEN
  COUNTER
}

enum station_type {
  KITCHEN
  BAR
  DESSERT
}
